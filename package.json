{
  "name": "live-ai-subtitle-translator",
  "version": "1.0.0",
  "description": "Real-time YouTube subtitle translation and AI-powered live captions",
  "main": "dist/background.js",
  "scripts": {
    "dev": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "npm run dev",
    "package": "npm run build && cd dist && zip -r ../extension.zip .",
    "analyze": "webpack-bundle-analyzer dist/js/*.js"
  },
  "keywords": [
    "youtube",
    "subtitles",
    "translation",
    "ai",
    "whisper",
    "chrome-extension",
    "brave-extension"
  ],
  "author": "Live AI Subtitle Translator Team",
  "license": "MIT",
  "dependencies": {
    "@types/chrome": "^0.0.251",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "framer-motion": "^10.16.16",
    "tailwindcss": "^3.3.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.1",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "postcss-loader": "^7.3.3",
    "html-webpack-plugin": "^5.6.0",
    "copy-webpack-plugin": "^11.0.0",
    "rimraf": "^5.0.5"
  }
}
